specification {
    element service
    element user
    element ui
    element node
}

model {
    user = user 'User' {
        description 'User of the system'
        -> webui 'uses'
    }
    webui = ui 'OpenWebUI' {
        description 'Interface to the server'
        -> openai_api 'uses'
    }
    server = node 'Server' {
        openai_api = service 'OpenAI API Service' {
            description 'Industry standard API for external use'
            -> llama_sever 'uses'
            -> manager 'uses'
        }
        manager = service 'Inference Management Service' {
            description 'Manages inference servers based on usage'
            -> llama_sever 'manages'
            -> tracker 'queries'
        }
        llama_sever = service 'llama-server' {
            description 'Provides inference'
            -> phone.rpc_server 'uses'
            -> linux_client.rpc_server 'uses'
        }
        tracker = service 'Tracker Service' {
            description 'Tracks node availabilty'
        }
    }
    phone = node 'Phone Node' {
        description 'Android phone running llama rpc server'
        rpc_server = service 'RPC Server' {
            description 'llama.cpp RPC server for inference'
        }
        heartbeat = service 'Heartbeat Service' {
            description 'Sends heartbeat to tracker'
            -> tracker 'announces to'
        }
    }
    linux_client = node 'Linux Node' {
        description 'Linux client running llama rpc server'
        rpc_server = service 'RPC Server' {
            description 'llama.cpp RPC server for inference'
        }
        heartbeat = service 'Heartbeat Service' {
            description 'Sends heartbeat to tracker'
            -> tracker 'announces to'
        }
    }
}

views {
    view index {
        include *
        include server.*
        include phone.*
        include linux_client.*
    }
}
